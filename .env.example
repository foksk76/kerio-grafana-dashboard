COMPOSE_PROJECT_NAME=kerio-grafana-dashboard

GRAFANA_HTTP_PORT=3000
GRAFANA_ROOT_URL=http://<grafana-host>:3000/
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=ChangeMe-Use-A-Strong-Password

ELASTICSEARCH_URL=http://<elasticsearch-host>:9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=ChangeMe-Elastic-Password
ELASTICSEARCH_FLOW_INDEX=kerio-flow-*
ELASTICSEARCH_EVENTS_INDEX=kerio-connect-*
